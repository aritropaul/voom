<div class="loading-state" id="loading-state">
  <div style="display:flex;justify-content:center;padding:48px 0 0">
    <img src="/icon-64.png" width="40" height="40" alt="Voom" style="border-radius:10px">
  </div>
  <div style="max-width:960px;margin:0 auto;padding:24px;display:flex;flex-direction:column;gap:48px;align-items:center">
    <div class="skeleton" style="width:100%;aspect-ratio:16/9;border-radius:14px"></div>
    <div style="display:flex;flex-direction:column;gap:12px;width:100%;max-width:720px">
      <div class="skeleton" style="width:50%;height:14px"></div>
      <div class="skeleton" style="width:30%;height:10px"></div>
    </div>
  </div>
</div>
