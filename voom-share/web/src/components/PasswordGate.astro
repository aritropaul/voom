<div class="centered-page" id="password-gate" style="display:none">
  <div class="centered-card">
    <div class="icon">🔒</div>
    <h1>This recording is protected</h1>
    <p>Enter the password to view this recording.</p>
    <input type="password" id="pw-input" placeholder="Password" autocomplete="off" autofocus>
    <div class="error" id="pw-error">Incorrect password. Please try again.</div>
    <button id="pw-submit">Unlock</button>
  </div>
</div>

<style>
  input {
    width: 100%;
    padding: 12px 16px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-s);
    color: #fff;
    font-size: 15px;
    outline: none;
    margin-bottom: 12px;
    font-family: inherit;
    transition: border-color 0.15s;
  }

  input:focus { border-color: var(--border-hover); }

  button {
    width: 100%;
    padding: 12px;
    background: #fff;
    color: #000;
    border: none;
    border-radius: var(--radius-s);
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.15s;
    font-family: inherit;
  }

  button:hover { opacity: 0.85; }

  .error {
    color: #ff4444;
    font-size: 13px;
    margin-bottom: 12px;
    display: none;
  }
</style>
